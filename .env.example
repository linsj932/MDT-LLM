# ──────────────────────────────────────────────────────────────
# MDT-LLM: API key template
# ──────────────────────────────────────────────────────────────
# 1. Copy this file:     cp .env.example .env.local
# 2. Fill in your keys below
# 3. Load keys:          source .env.local
# 4. Run experiment:     python src/run_experiment.py
#
# .env.local is git-ignored; it will NOT be pushed.
# ──────────────────────────────────────────────────────────────

# OpenAI (for GPT-4o-mini + text-embedding-3-large)
# Get key at: https://platform.openai.com/api-keys
export OPENAI_API_KEY="sk-..."

# Anthropic (for Claude Sonnet 4.5)
# Get key at: https://console.anthropic.com/
export ANTHROPIC_API_KEY="sk-ant-api03-..."

# DeepSeek (for DeepSeek R1)
# Get key at: https://platform.deepseek.com/
export DEEPSEEK_API_KEY="sk-..."

# Together AI (for Llama-3.3-70B)
# Get key at: https://api.together.xyz/settings/api-keys
export TOGETHER_API_KEY="tgp_v1_..."
